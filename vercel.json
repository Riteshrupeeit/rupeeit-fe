{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
      {
        "source": "/.well-known/:path*",
        "destination": "/.well-known/:path*"
      },
      { "source": "/(.*)", "destination": "/" }
    ],
    "headers": [
      {
        "source": "/.well-known/(.*)",
        "headers": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      }
    ]
  }
  